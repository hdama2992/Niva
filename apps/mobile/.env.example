EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_REALTIME_URL=http://localhost:3001

# Use beta only for a local preview. Production must use firebase.
EXPO_PUBLIC_AUTH_MODE=beta

# Native Firebase reads google-services.json on Android. Keep that file local
# and gitignored, or upload it to EAS as the GOOGLE_SERVICES_JSON secret file
# variable. Never expose Firebase service-account credentials to the app.

# Created by `eas init`. Required when obtaining an Expo push token.
EXPO_PUBLIC_EAS_PROJECT_ID=

# Android-only Firebase Phone Number Verification. Keep disabled until the
# native Android build and backend token exchange are configured.
EXPO_PUBLIC_FIREBASE_PNV_ENABLED=false

# Test-only token from Firebase Console > Phone Verification > Testing.
# Do not set this in a production build.
EXPO_PUBLIC_FIREBASE_PNV_TEST_TOKEN=
