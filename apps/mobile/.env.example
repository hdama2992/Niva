EXPO_PUBLIC_API_URL=http://localhost:3001

# Use beta only for a local preview. Production must use firebase.
EXPO_PUBLIC_AUTH_MODE=beta

# Copy these values from Firebase Console > Project settings > Your apps > Web app.
# Do not put Firebase service-account credentials in this file.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
