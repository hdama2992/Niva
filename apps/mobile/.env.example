EXPO_PUBLIC_API_URL=https://your-project.web.app/api

EXPO_PUBLIC_AUTH_MODE=firebase

# Local QA only. Production builds must leave this false or unset. When true,
# use http://127.0.0.1:5001/your-project/asia-south1/api for EXPO_PUBLIC_API_URL
# and forward ports 5001, 9099, and 9199 to a physical Android device with ADB.
EXPO_PUBLIC_USE_FIREBASE_EMULATOR=false

# Native Firebase reads google-services.json on Android. Keep that file local
# and gitignored, or upload it to EAS as the GOOGLE_SERVICES_JSON secret file
# variable. Never expose Firebase service-account credentials to the app.

# Created by `eas init`. Required for EAS builds and project ownership.
EXPO_PUBLIC_EAS_PROJECT_ID=

EXPO_PUBLIC_PRIVACY_POLICY_URL=https://your-project.web.app/privacy
EXPO_PUBLIC_SUPPORT_URL=https://your-project.web.app/support
EXPO_PUBLIC_TERMS_URL=https://your-project.web.app/terms
