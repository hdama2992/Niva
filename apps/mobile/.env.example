EXPO_PUBLIC_API_URL=http://localhost:3001

EXPO_PUBLIC_AUTH_MODE=firebase

# Native Firebase reads google-services.json on Android. Keep that file local
# and gitignored, or upload it to EAS as the GOOGLE_SERVICES_JSON secret file
# variable. Never expose Firebase service-account credentials to the app.

# Created by `eas init`. Required for EAS builds and project ownership.
EXPO_PUBLIC_EAS_PROJECT_ID=
