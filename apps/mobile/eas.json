{
  "cli": {
    "appVersionSource": "remote",
    "version": ">= 16.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development"
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview"
    },
    "closed-test": {
      "android": {
        "buildType": "app-bundle"
      },
      "autoIncrement": true,
      "distribution": "store",
      "environment": "preview"
    },
    "production": {
      "autoIncrement": true,
      "distribution": "store",
      "environment": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
