{
  "name": "@niva/backend",
  "version": "1.0.0",
  "description": "Niva Firebase Cloud Functions backend",
  "private": true,
  "license": "UNLICENSED",
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.firebase.json",
    "dev": "pnpm build && firebase emulators:start --only auth,firestore,functions,storage",
    "format": "prettier --write \"firebase-src/**/*.ts\"",
    "lint": "eslint \"firebase-src/**/*.ts\"",
    "lint:fix": "eslint \"firebase-src/**/*.ts\" --fix",
    "serve": "pnpm build && firebase emulators:start --only auth,firestore,functions,storage",
    "shell": "pnpm build && firebase functions:shell",
    "start": "pnpm shell",
    "test": "pnpm build && node --test firebase-src/*.test.mjs",
    "test:emulator": "pnpm build && firebase emulators:exec --project niva-staging --only auth,firestore,functions,storage \"node firebase-src/emulator.e2e.mjs\"",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "express": "^5.1.0",
    "firebase-admin": "^14.1.0",
    "firebase-functions": "^7.3.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
