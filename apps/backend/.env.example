# Comma-separated web origins. Native mobile requests do not send Origin.
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3003,http://localhost:5000"

# Local emulator-only bootstrap value. Production uses Firebase Secret Manager:
# firebase functions:secrets:set NIVA_ADMIN_KEY
NIVA_ADMIN_KEY="replace-with-a-long-random-local-key"

# Cloud Functions automatically receives Firebase Admin credentials.
# No service-account JSON or database connection is required.
