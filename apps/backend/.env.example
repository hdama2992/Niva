DATABASE_URL="postgresql://niva:niva@localhost:5432/niva?schema=public"
PORT=3001
ADMIN_ORIGIN="http://localhost:3000"
MOBILE_ORIGIN="http://localhost:8081"
DOCS_ORIGIN="http://localhost:3002"
WEBSITE_ORIGIN="http://localhost:3003"
NIVA_ADMIN_KEY="replace-with-local-review-key"
NIVA_BETA_AUTH_ENABLED="true"

# Global API protection. Override only after observing real traffic.
NIVA_RATE_LIMIT_TTL_MS="60000"
NIVA_RATE_LIMIT_REQUESTS="120"
REQUEST_BODY_LIMIT="1mb"

# Firebase Admin service-account values. Keep the real values only in .env.
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_STORAGE_BUCKET=""

# Optional for authenticated Expo push requests. Leave empty while developing.
EXPO_PUSH_ACCESS_TOKEN=""
NIVA_NOTIFICATION_DISPATCH_MINUTES=""

# Android-only Firebase Phone Number Verification (PNV) is optional.
# It remains disabled until Firebase billing, OAuth brand verification, and
# the native Android build have been configured.
FIREBASE_PNV_ENABLED="false"
FIREBASE_PROJECT_NUMBER=""
