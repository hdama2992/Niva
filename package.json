{
  "name": "niva",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "turbo run build",
    "docs:dev": "pnpm --filter @niva/docs dev",
    "dev": "turbo run dev --parallel",
    "firebase:deploy": "firebase deploy",
    "firebase:deploy:backend": "firebase deploy --only functions,firestore,storage",
    "firebase:emulators": "pnpm --filter @niva/backend build && firebase emulators:start",
    "firebase:hosting:build": "NEXT_PUBLIC_API_URL=/api pnpm --filter @niva/website build && NEXT_PUBLIC_API_URL=/api pnpm --filter @niva/admin build && node scripts/prepare-firebase-hosting.mjs",
    "format": "prettier --write .",
    "lint": "turbo run lint",
    "mobile:start": "pnpm --filter @niva/mobile start",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "firebase-tools": "^14.0.0",
    "prettier": "^3.6.2",
    "turbo": "^2.5.5"
  }
}
