{
  "name": "niva",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "turbo run build",
    "db:down": "docker compose -f docker/postgres/compose.yml down",
    "db:migrate": "pnpm --filter @niva/backend prisma:migrate",
    "db:migrate:deploy": "pnpm --filter @niva/backend prisma:migrate:deploy",
    "db:studio": "pnpm --filter @niva/backend prisma:studio",
    "db:up": "docker compose -f docker/postgres/compose.yml up -d",
    "docs:dev": "pnpm --filter @niva/docs dev",
    "dev": "turbo run dev --parallel",
    "format": "prettier --write .",
    "lint": "turbo run lint",
    "mobile:start": "pnpm --filter @niva/mobile start",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.5.5"
  }
}
